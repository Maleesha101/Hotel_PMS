# Environment variables for Auth Service

# Server
NODE_ENV=development
PORT=8081

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/auth_db

# Redis
REDIS_URL=redis://localhost:6381

# JWT Keys (multiline PEM strings)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# JWT TTLs
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Admin seed (development)
ADMIN_SEED_EMAIL=admin@hotelpms.com
ADMIN_SEED_PASSWORD=Admin@1234!
ADMIN_SEED_NAME=System Admin
