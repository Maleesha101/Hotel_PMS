# Environment variables for housekeeping-service
APP_NAME=housekeeping-service
APP_PORT=8082
ENVIRONMENT=dev

# Database URL (asyncpg)
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/housekeeping_db

# Redis URL
REDIS_URL=redis://localhost:6380/0

# Kafka configuration
KAFKA_BOOTSTRAP=localhost:9093
KAFKA_CONSUMER_GROUP=housekeeping-service

# JWT public key (RS256 PEM format) - set this in your environment or secret manager
JWT_PUBLIC_KEY=

# Scheduler cron for low stock check (default daily at 07:00)
LOW_STOCK_CHECK_CRON=0 7 * * *
